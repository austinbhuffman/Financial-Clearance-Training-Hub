PORT=8080
AUTH_MODE=mock
SESSION_TTL_MS=43200000

# Mock mode bootstrap accounts
BOOTSTRAP_SUPERVISOR_EMAIL=supervisor@financialclearance.local
BOOTSTRAP_SUPERVISOR_NAME=Financial Clearance Supervisor
BOOTSTRAP_SUPERVISOR_TEAM=Leadership
BOOTSTRAP_SUPERVISOR_TEMP_PASSWORD=TempPass123!

BOOTSTRAP_TRAINEE_EMAIL=trainee@financialclearance.local
BOOTSTRAP_TRAINEE_NAME=New Trainee
BOOTSTRAP_TRAINEE_TEAM=Patient Access
BOOTSTRAP_TRAINEE_TEMP_PASSWORD=TempPass123!

# Cognito mode (set AUTH_MODE=cognito)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_USE_CUSTOM_ATTRS=false

